# =============================================================================
# Stripe Checkout Starter — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Stripe — Server (secret, never exposed to browser)
# -----------------------------------------------------------------------------

# Your Stripe secret key (find it at https://dashboard.stripe.com/apikeys)
# Use sk_test_ keys for development, sk_live_ for production.
STRIPE_SECRET_KEY=sk_test_

# Webhook signing secret (find it after running `stripe listen` or in Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_

# Customer Portal: configure at https://dashboard.stripe.com/settings/billing/portal
# Then enable it in payments.config.ts -> customerPortal.enabled = true

# -----------------------------------------------------------------------------
# Upstash Redis — Rate Limiting (optional)
# -----------------------------------------------------------------------------

# Rate limiting for checkout and portal session creation.
# Sign up at https://console.upstash.com and create a Redis database.
# Without these, rate limiting is disabled (app works fine without it).
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...

# -----------------------------------------------------------------------------
# Stripe — Client (public, safe for browser)
# -----------------------------------------------------------------------------

# Your Stripe publishable key (find it at https://dashboard.stripe.com/apikeys)
# Use pk_test_ keys for development, pk_live_ for production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# (Optional) The canonical URL of your deployed app.
# Used for Stripe success/cancel redirect URLs.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
