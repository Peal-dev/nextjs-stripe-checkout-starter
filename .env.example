# =============================================================================
# Stripe Checkout Starter — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Stripe — Server (secret, never exposed to browser)
# -----------------------------------------------------------------------------

# Your Stripe secret key (find it at https://dashboard.stripe.com/apikeys)
# Use sk_test_ keys for development, sk_live_ for production.
STRIPE_SECRET_KEY=sk_test_

# Webhook signing secret (find it after running `stripe listen` or in Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_

# (Optional) Stripe Customer Portal URL
# Create one at https://dashboard.stripe.com/test/settings/billing/portal
# STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/test_xxx

# -----------------------------------------------------------------------------
# Stripe — Client (public, safe for browser)
# -----------------------------------------------------------------------------

# Your Stripe publishable key (find it at https://dashboard.stripe.com/apikeys)
# Use pk_test_ keys for development, pk_live_ for production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# (Optional) The canonical URL of your deployed app.
# Used for Stripe success/cancel redirect URLs.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
